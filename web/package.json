{
  "name": "subout-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src --fix",
    "typecheck": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,vue,css}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.6"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "element-plus": "^2.9.1",
    "@element-plus/icons-vue": "^2.3.1",
    "vuedraggable": "^4.1.0",
    "vue": "^3.5.39"
  }
}
